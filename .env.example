# ── CAS PDF ──────────────────────────────────────────────────────────────────
# Path to your CAS PDF (Consolidated Account Statement)
# Download from: MF Central (mfcentral.com) or CAMS/KFintech
CAS_PDF_PATH=data/cas.pdf

# Password format: PAN (uppercase) + DOB as DDMMYYYY
# Example: ABCDE1234F01011990
CAS_PASSWORD=pgattu1988

# ── User Profile Defaults ────────────────────────────────────────────────────
# These are overridden by the interactive prompt; set here for scripted runs
USER_AGE=30
USER_GOAL=Retirement corpus
USER_HORIZON_YEARS=15
USER_RISK_APPETITE=Moderate
USER_MONTHLY_SIP_BUDGET=25000

# ── LLM (LM Studio) ─────────────────────────────────────────────────────────
# Local LLM server (LM Studio / Ollama / any OpenAI-compatible API)
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=not-needed
LLM_TEMPERATURE=0.3
